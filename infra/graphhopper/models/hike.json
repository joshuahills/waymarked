{
  "speed": [
    {
      "if": "average_slope > 15",
      "multiply_by": "0.6"
    },
    {
      "if": "average_slope > 10 && average_slope <= 15",
      "multiply_by": "0.8"
    }
  ],
  "priority": [
    {
      "if": "hiking_rating >= 3",
      "multiply_by": "1.4"
    },
    {
      "if": "highway == BRIDLEWAY",
      "multiply_by": "1.2"
    }
  ],
  "distance_influence": 60
}
