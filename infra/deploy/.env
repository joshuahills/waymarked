# Postgres superuser password — REQUIRED, set a strong value in production
POSTGRES_PASSWORD=

# Bind mount source for caddy:/etc/caddy/Caddyfile
CADDY_BINDMOUNT_0=

# Bind mount source for caddy:/data
CADDY_BINDMOUNT_1=

# Bind mount source for caddy:/config
CADDY_BINDMOUNT_2=

# Bind mount source for graphhopper:/data/config.yml
GRAPHHOPPER_BINDMOUNT_0=

# Bind mount source for graphhopper:/data
GRAPHHOPPER_BINDMOUNT_1=

# Container image name for graphhopper
GRAPHHOPPER_IMAGE=

# Container image name for waymarked-api
WAYMARKED_API_IMAGE=

# Default container port for waymarked-api
WAYMARKED_API_PORT=

# Container image name for waymarked-web
WAYMARKED_WEB_IMAGE=

# Default container port for waymarked-web
WAYMARKED_WEB_PORT=

