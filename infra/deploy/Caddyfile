# Caddy reverse proxy for Waymarked
# Auto-provisions a Let's Encrypt TLS certificate for the domain.
# Proxies all traffic to the waymarked-web container (which itself proxies
# /api/* requests to waymarked-api via YARP).

waymarked.hills.dev {
    reverse_proxy waymarked-web:8080

    # Compress responses
    encode gzip

    # Security headers
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
    }

    # Access logs
    log {
        output file /var/log/caddy/access.log {
            roll_size 10mb
            roll_keep 5
        }
    }
}
